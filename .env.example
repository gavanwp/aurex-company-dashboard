# AurexOS environment configuration
# Copy to .env.local (apps/web reads it via Next.js). Never commit real values.
# All env access goes through apps/web/lib/env.ts — no process.env elsewhere.

# ── Supabase ────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Server-only. Bypasses RLS — used exclusively for admin/system operations.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI (Phase 3 — placeholders, unused in Phase 1) ─────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
